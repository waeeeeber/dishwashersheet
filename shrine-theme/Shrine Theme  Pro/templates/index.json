    "varino_faq": {
      "type": "collapsible-content",
      "blocks": {
        "faq_1": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Wie viele Waschgänge schaffe ich pro Pack?",
            "row_content": "<p>In einer VARINO-Box sind 30 papierdünne Streifen. Da Sie diese an der vorgesehenen Perforation halbieren können, kommen Sie auf bis zu 60 Waschgänge pro Pack — bei normaler Verschmutzung.</p>"
          }
        },
        "faq_2": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Wann sollte ich einen ganzen, wann einen halben Streifen verwenden?",
            "row_content": "<p>Halber Streifen: kleine Spülmenge, Glas und leicht verschmutztes Geschirr. Ganzer Streifen: voll beladene Maschine, eingebrannte Reste, Pfannen oder besonders hartes Wasser.</p>"
          }
        },
        "faq_3": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Wo lege ich den Streifen in die Spülmaschine?",
            "row_content": "<p>Sie können den VARINO-Streifen direkt in das Tab-Fach legen oder, bei sehr eng dosierten Fächern, einfach lose auf den Geschirrkorb. Er löst sich rückstandslos auf.</p>"
          }
        },
        "faq_4": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Ist VARINO wirklich plastikfrei?",
            "row_content": "<p>Ja. Sowohl die Streifen selbst als auch die Verpackung sind frei von Mikroplastik. Die Box ist vollständig kompostierbar — eine kleine, aber konsequente Geste für unsere Umwelt.</p>"
          }
        },
        "faq_5": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Wirkt VARINO auch bei hartem Wasser?",
            "row_content": "<p>Absolut. Unsere Rezeptur enthält natürliche Wasserenthärter und Klarspüler-Enzyme. Wir empfehlen dennoch, Salz im Vorratsbehälter Ihrer Maschine aufzufüllen.</p>"
          }
        },
        "faq_6": {
          "type": "collapsible-row",
          "settings": {
            "heading": "Wie schnell wird geliefert?",
            "row_content": "<p>Wir versenden innerhalb von 24 Stunden klimaneutral aus Deutschland. Die Lieferung erreicht Sie in der Regel nach 2–3 Werktagen.</p>"
          }
        }
      },
      "block_order": ["faq_1", "faq_2", "faq_3", "faq_4", "faq_5", "faq_6"],
