    "varino_steps": {
      "type": "custom-liquid",
      "settings": {
        "display_id": false,
        "visibility": "always-display",
        "custom_liquid": "<style>\n  .varino-steps{width:100vw;left:50%;right:50%;margin-left:-50vw;margin-right:-50vw;position:relative;background:#EBE3D2;padding:110px 24px;}\n  .varino-steps__inner{max-width:1280px;margin:0 auto;}\n  .varino-steps__head{text-align:center;margin-bottom:80px;}\n  .varino-steps__eyebrow{font-family:'Lora',serif;font-size:11px;letter-spacing:.4em;text-transform:uppercase;color:#A37D5A;margin-bottom:18px;display:inline-block;}\n  .varino-steps__title{font-family:'Playfair Display',serif;font-weight:500;font-size:clamp(32px,4vw,54px);color:#1B3A2F;margin:0;line-height:1.1;}\n  .varino-steps__title em{font-style:italic;color:#A37D5A;}\n  .varino-steps__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}\n  .varino-steps__card{background:#F5EFE6;padding:48px 36px;text-align:left;position:relative;border:1px solid rgba(27,58,47,.08);}\n  .varino-steps__num{font-family:'Playfair Display',serif;font-style:italic;font-size:62px;color:#A37D5A;line-height:1;margin-bottom:18px;display:block;}\n  .varino-steps__h{font-family:'Playfair Display',serif;font-weight:500;font-size:24px;color:#1B3A2F;margin:0 0 14px;}\n  .varino-steps__p{font-family:'Lora',serif;font-size:15px;line-height:1.7;color:#2A3B33;margin:0;opacity:.85;}\n  @media (max-width:899px){.varino-steps__grid{grid-template-columns:1fr;}.varino-steps{padding:70px 16px;}}\n</style>\n<section class=\"varino-steps\">\n  <div class=\"varino-steps__inner\">\n    <div class=\"varino-steps__head\">\n      <span class=\"varino-steps__eyebrow\">Anwendung</span>\n      <h2 class=\"varino-steps__title\">In drei <em>einfachen</em> Schritten zu reinem Glanz.</h2>\n    </div>\n    <div class=\"varino-steps__grid\">\n      <div class=\"varino-steps__card\">\n        <span class=\"varino-steps__num\">01</span>\n        <h3 class=\"varino-steps__h\">Streifen entnehmen</h3>\n        <p class=\"varino-steps__p\">Öffnen Sie die Box und entnehmen Sie einen papierdünnen VARINO-Streifen. Bei leicht verschmutztem Geschirr genügt die Hälfte – einfach an der Perforation teilen.</p>\n      </div>\n      <div class=\"varino-steps__card\">\n        <span class=\"varino-steps__num\">02</span>\n        <h3 class=\"varino-steps__h\">In die Maschine geben</h3>\n        <p class=\"varino-steps__p\">Legen Sie den Streifen in das Tab-Fach oder direkt in den Innenraum. Programm wählen — fertig. Keine Folie, kein Pulverstaub.</p>\n      </div>\n      <div class=\"varino-steps__card\">\n        <span class=\"varino-steps__num\">03</span>\n        <h3 class=\"varino-steps__h\">Glanz genießen</h3>\n        <p class=\"varino-steps__p\">VARINO löst sich vollständig auf und entfaltet seine konzentrierte Reinigungskraft – für streifenfrei klares Geschirr und strahlenden Glanz.</p>\n      </div>\n    </div>\n  </div>\n</section>",
        "color_scheme": "background-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "varino_testimonials": {
      "type": "testimonials",
      "blocks": {
        "tst_1": {
          "type": "column",
          "settings": {
            "name": "Lena W.",
            "name_color": "#1B3A2F",
            "subname": "Hamburg",
            "subname_color": "#A37D5A",
            "stars": 5,
            "star_color": "#A37D5A",
            "star_size": 18,
            "review": "<p>Endlich ein Spülmittel, das man stehen lassen kann. Die Box ist so schön, ich habe sie auf der Anrichte. Geschirr glänzt wie nie.</p>"
          }
        },
        "tst_2": {
          "type": "column",
          "settings": {
            "name": "Maximilian B.",
            "name_color": "#1B3A2F",
            "subname": "München",
            "subname_color": "#A37D5A",
            "stars": 5,
            "star_color": "#A37D5A",
            "star_size": 18,
            "review": "<p>Plastikfrei, hochkonzentriert und einfach genial. Halbiere die Streifen und komme jetzt zwei Monate mit einer Box aus.</p>"
          }
        },
        "tst_3": {
          "type": "column",
          "settings": {
            "name": "Charlotte M.",
            "name_color": "#1B3A2F",
            "subname": "Berlin",
            "subname_color": "#A37D5A",
            "stars": 5,
            "star_color": "#A37D5A",
            "star_size": 18,
            "review": "<p>Riecht dezent, dosiert sich von selbst und reinigt makellos. Das Beste: kein Plastikmüll mehr unter der Spüle.</p>"
          }
        },
        "tst_4": {
          "type": "column",
          "settings": {
            "name": "Felix R.",
            "name_color": "#1B3A2F",
            "subname": "Frankfurt",
            "subname_color": "#A37D5A",
            "stars": 5,
            "star_color": "#A37D5A",
            "star_size": 18,
            "review": "<p>Habe lange nach einer eleganten Alternative zu Tabs gesucht. VARINO sieht hochwertig aus und funktioniert tadellos – auch bei Eingebranntem.</p>"
          }
        }
      },
      "block_order": ["tst_1", "tst_2", "tst_3", "tst_4"],
      "settings": {
        "display_id": false,
